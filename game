<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GamePulse — The Future of Gaming News</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Exo+2:ital,wght@0,300;0,400;0,600;0,700;0,900;1,400&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #020408;
  --bg2: #080e18;
  --bg3: #0c1420;
  --bg4: #111d2e;
  --neon-blue: #00d4ff;
  --neon-purple: #8b5cf6;
  --neon-pink: #f472b6;
  --neon-green: #00ff88;
  --accent: #0ea5e9;
  --text: #e2e8f0;
  --text-muted: #64748b;
  --text-dim: #334155;
  --border: rgba(0,212,255,0.15);
  --border2: rgba(139,92,246,0.2);
  --glow: 0 0 20px rgba(0,212,255,0.3);
  --glow-purple: 0 0 20px rgba(139,92,246,0.4);
  --radius: 8px;
  --radius-lg: 14px;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Exo 2', sans-serif;
  font-size: 15px;
  line-height: 1.6;
  overflow-x: hidden;
}

/* SCANLINE OVERLAY */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.03) 2px, rgba(0,0,0,0.03) 4px);
  pointer-events: none;
  z-index: 9999;
}

/* SCROLLBAR */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--neon-blue); border-radius: 3px; }

/* TYPOGRAPHY */
h1,h2,h3,h4,h5 { font-family: 'Rajdhani', sans-serif; letter-spacing: 0.02em; line-height: 1.2; }
.mono { font-family: 'Share Tech Mono', monospace; }

/* ── BREAKING NEWS TICKER ── */
.ticker-wrap {
  background: linear-gradient(90deg, var(--neon-blue), var(--neon-purple));
  padding: 0;
  overflow: hidden;
  position: relative;
  z-index: 100;
}
.ticker-label {
  display: inline-block;
  background: #ff1744;
  color: #fff;
  font-family: 'Rajdhani', sans-serif;
  font-weight: 700;
  font-size: 11px;
  letter-spacing: 2px;
  padding: 8px 16px;
  text-transform: uppercase;
  vertical-align: middle;
  white-space: nowrap;
  animation: pulse-label 1.5s ease-in-out infinite;
}
@keyframes pulse-label { 0%,100%{opacity:1} 50%{opacity:0.7} }
.ticker-track {
  display: inline-block;
  white-space: nowrap;
  animation: ticker 40s linear infinite;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.05em;
  color: #fff;
  padding: 8px 0;
  vertical-align: middle;
}
.ticker-track span { margin: 0 40px; }
.ticker-track span::before { content: '◆ '; opacity: 0.6; }
@keyframes ticker { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }

/* ── NAVBAR ── */
nav {
  position: sticky;
  top: 0;
  z-index: 90;
  background: rgba(2,4,8,0.92);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
  padding: 0 24px;
  display: flex;
  align-items: center;
  gap: 0;
  height: 60px;
}
.nav-logo {
  font-family: 'Rajdhani', sans-serif;
  font-size: 26px;
  font-weight: 700;
  letter-spacing: 0.05em;
  color: #fff;
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 8px;
  margin-right: 32px;
  white-space: nowrap;
}
.logo-icon {
  width: 32px;
  height: 32px;
  background: linear-gradient(135deg, var(--neon-blue), var(--neon-purple));
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  box-shadow: var(--glow);
}
.logo-pulse { color: var(--neon-blue); }
.nav-links {
  display: flex;
  align-items: center;
  gap: 4px;
  flex: 1;
  overflow-x: auto;
  scrollbar-width: none;
}
.nav-links::-webkit-scrollbar { display: none; }
.nav-link {
  color: var(--text-muted);
  text-decoration: none;
  font-family: 'Rajdhani', sans-serif;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 6px 14px;
  border-radius: var(--radius);
  transition: all 0.2s;
  white-space: nowrap;
}
.nav-link:hover { color: var(--neon-blue); background: rgba(0,212,255,0.07); }
.nav-link.active { color: var(--neon-blue); background: rgba(0,212,255,0.1); }
.nav-search {
  display: flex;
  align-items: center;
  gap: 8px;
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 6px 12px;
  margin-left: 12px;
  transition: border-color 0.2s;
  min-width: 200px;
}
.nav-search:focus-within { border-color: var(--neon-blue); box-shadow: var(--glow); }
.nav-search input {
  background: none;
  border: none;
  outline: none;
  color: var(--text);
  font-family: 'Exo 2', sans-serif;
  font-size: 13px;
  width: 100%;
}
.nav-search input::placeholder { color: var(--text-dim); }
.nav-search svg { color: var(--text-muted); flex-shrink: 0; }
.nav-btn {
  background: linear-gradient(135deg, var(--neon-blue), var(--neon-purple));
  color: #fff;
  border: none;
  border-radius: var(--radius);
  padding: 8px 18px;
  font-family: 'Rajdhani', sans-serif;
  font-weight: 700;
  font-size: 13px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  cursor: pointer;
  margin-left: 12px;
  white-space: nowrap;
  transition: opacity 0.2s, transform 0.15s;
}
.nav-btn:hover { opacity: 0.9; transform: translateY(-1px); }

/* ── LAYOUT ── */
.container { max-width: 1280px; margin: 0 auto; padding: 0 20px; }
main { display: grid; grid-template-columns: 1fr 320px; gap: 32px; padding: 32px 20px; max-width: 1280px; margin: 0 auto; }
@media(max-width:900px){ main { grid-template-columns: 1fr; } }

/* ── HERO ── */
.hero {
  position: relative;
  overflow: hidden;
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
  padding: 60px 20px 50px;
}
.hero-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; max-width: 1280px; margin: 0 auto; }
@media(max-width:768px){ .hero-grid { grid-template-columns: 1fr; } }

.hero-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 60% at 70% 50%, rgba(139,92,246,0.12) 0%, transparent 70%),
    radial-gradient(ellipse 40% 80% at 20% 30%, rgba(0,212,255,0.08) 0%, transparent 70%);
  pointer-events: none;
}
.hero-grid-lines {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(0,212,255,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,212,255,0.04) 1px, transparent 1px);
  background-size: 40px 40px;
  pointer-events: none;
}

.hero-featured {
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
  cursor: pointer;
  group: featured;
  transition: transform 0.3s;
}
.hero-featured:hover { transform: translateY(-3px); }
.hero-img {
  width: 100%;
  aspect-ratio: 16/9;
  object-fit: cover;
  display: block;
}
.hero-img-placeholder {
  width: 100%;
  aspect-ratio: 16/9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80px;
  position: relative;
  overflow: hidden;
}
.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.3) 50%, transparent 100%);
}
.hero-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24px;
}
.tag {
  display: inline-block;
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  padding: 4px 10px;
  border-radius: 4px;
  margin-bottom: 10px;
}
.tag-blue { background: rgba(0,212,255,0.2); color: var(--neon-blue); border: 1px solid rgba(0,212,255,0.3); }
.tag-purple { background: rgba(139,92,246,0.2); color: #a78bfa; border: 1px solid rgba(139,92,246,0.3); }
.tag-pink { background: rgba(244,114,182,0.2); color: var(--neon-pink); border: 1px solid rgba(244,114,182,0.3); }
.tag-green { background: rgba(0,255,136,0.15); color: var(--neon-green); border: 1px solid rgba(0,255,136,0.3); }
.tag-red { background: rgba(255,23,68,0.2); color: #ff6b6b; border: 1px solid rgba(255,23,68,0.3); }
.hero-content h2 { font-size: 26px; font-weight: 700; color: #fff; margin-bottom: 8px; line-height: 1.2; }
.hero-meta { display: flex; align-items: center; gap: 12px; font-size: 12px; color: rgba(255,255,255,0.6); }

.hero-sidebar { display: flex; flex-direction: column; gap: 16px; }

/* ── SECTION HEADER ── */
.section-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 20px;
}
.section-line {
  flex: 1;
  height: 1px;
  background: linear-gradient(90deg, var(--border) 0%, transparent 100%);
}
.section-title {
  font-family: 'Rajdhani', sans-serif;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--neon-blue);
  white-space: nowrap;
}

/* ── ARTICLE CARD ── */
.article-card {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  transition: all 0.25s;
  cursor: pointer;
  display: flex;
  flex-direction: column;
}
.article-card:hover {
  border-color: rgba(0,212,255,0.35);
  box-shadow: var(--glow);
  transform: translateY(-2px);
}
.card-thumb {
  width: 100%;
  aspect-ratio: 16/9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48px;
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
}
.card-thumb-sm {
  width: 100px;
  height: 68px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  border-radius: var(--radius);
  flex-shrink: 0;
  overflow: hidden;
  position: relative;
}
.card-body { padding: 16px; flex: 1; }
.card-title { font-family: 'Rajdhani', sans-serif; font-size: 17px; font-weight: 600; color: #fff; line-height: 1.3; margin-bottom: 8px; }
.card-title-sm { font-family: 'Rajdhani', sans-serif; font-size: 15px; font-weight: 600; color: #fff; line-height: 1.3; margin-bottom: 4px; }
.card-excerpt { font-size: 13px; color: var(--text-muted); line-height: 1.5; }
.card-meta { display: flex; align-items: center; gap: 10px; font-size: 11px; color: var(--text-dim); margin-top: 10px; }
.card-meta span { display: flex; align-items: center; gap: 4px; }
.card-row { display: flex; gap: 12px; align-items: flex-start; cursor: pointer; transition: opacity 0.2s; }
.card-row:hover { opacity: 0.85; }

.articles-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }
.articles-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
@media(max-width:600px){ .articles-grid-2 { grid-template-columns: 1fr; } }

/* ── GAME CATEGORIES ── */
.categories-scroll {
  display: flex;
  gap: 10px;
  overflow-x: auto;
  padding-bottom: 8px;
  scrollbar-width: none;
  margin-bottom: 24px;
}
.categories-scroll::-webkit-scrollbar { display: none; }
.cat-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 14px 20px;
  cursor: pointer;
  transition: all 0.2s;
  min-width: 90px;
  text-align: center;
}
.cat-btn:hover, .cat-btn.active {
  border-color: var(--neon-blue);
  background: rgba(0,212,255,0.08);
  box-shadow: var(--glow);
}
.cat-icon { font-size: 28px; line-height: 1; }
.cat-name { font-family: 'Rajdhani', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 0.05em; color: var(--text-muted); white-space: nowrap; }
.cat-btn.active .cat-name { color: var(--neon-blue); }

/* ── SIDEBAR ── */
.sidebar { display: flex; flex-direction: column; gap: 24px; }
.sidebar-box {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 20px;
}

/* ── TRENDING LIST ── */
.trending-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 12px 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
  cursor: pointer;
  transition: all 0.2s;
}
.trending-item:last-child { border-bottom: none; }
.trending-item:hover .trending-title { color: var(--neon-blue); }
.trending-num {
  font-family: 'Share Tech Mono', monospace;
  font-size: 20px;
  font-weight: 700;
  color: var(--text-dim);
  min-width: 28px;
  line-height: 1;
  padding-top: 2px;
}
.trending-item:hover .trending-num { color: var(--neon-blue); }
.trending-title { font-family: 'Rajdhani', sans-serif; font-size: 15px; font-weight: 600; color: var(--text); line-height: 1.3; }
.trending-game { font-size: 11px; color: var(--text-muted); margin-top: 3px; }

/* ── LIVE SCORES / ESPORTS ── */
.esport-match {
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 14px;
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 10px;
  transition: border-color 0.2s;
  cursor: pointer;
}
.esport-match:hover { border-color: rgba(0,212,255,0.3); }
.team { display: flex; flex-direction: column; align-items: center; flex: 1; }
.team-icon { font-size: 28px; line-height: 1; }
.team-name { font-family: 'Rajdhani', sans-serif; font-size: 13px; font-weight: 700; color: #fff; margin-top: 4px; }
.score-box { text-align: center; }
.score-text { font-family: 'Share Tech Mono', monospace; font-size: 22px; color: #fff; letter-spacing: 2px; }
.live-badge {
  display: inline-block;
  background: #ff1744;
  color: #fff;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 1px;
  padding: 2px 6px;
  border-radius: 3px;
  animation: pulse-label 1s infinite;
  margin-bottom: 4px;
}
.vs { color: var(--text-dim); font-size: 12px; }

/* ── UPCOMING RELEASES ── */
.release-item {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 12px 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
  cursor: pointer;
}
.release-item:last-child { border-bottom: none; }
.release-date-box {
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 8px 12px;
  text-align: center;
  min-width: 56px;
  flex-shrink: 0;
}
.release-month { font-size: 10px; color: var(--neon-blue); font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; }
.release-day { font-family: 'Rajdhani', sans-serif; font-size: 22px; font-weight: 700; color: #fff; line-height: 1; }
.release-name { font-family: 'Rajdhani', sans-serif; font-size: 16px; font-weight: 600; color: #fff; }
.release-platform { font-size: 11px; color: var(--text-muted); }

/* ── POPULAR GAMES ── */
.game-card {
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 16px;
  display: flex;
  align-items: center;
  gap: 14px;
  cursor: pointer;
  transition: all 0.2s;
}
.game-card:hover {
  border-color: var(--neon-purple);
  background: rgba(139,92,246,0.06);
}
.game-icon { font-size: 36px; flex-shrink: 0; }
.game-name { font-family: 'Rajdhani', sans-serif; font-size: 17px; font-weight: 700; color: #fff; }
.game-players { font-size: 12px; color: var(--neon-green); }
.game-genre { font-size: 11px; color: var(--text-muted); margin-top: 2px; }
.game-bar-wrap { flex: 1; background: var(--bg4); border-radius: 2px; height: 4px; margin-top: 8px; }
.game-bar { height: 4px; border-radius: 2px; background: linear-gradient(90deg, var(--neon-blue), var(--neon-purple)); }

/* ── NEWSLETTER ── */
.newsletter {
  background: linear-gradient(135deg, rgba(0,212,255,0.08) 0%, rgba(139,92,246,0.08) 100%);
  border: 1px solid var(--border2);
  border-radius: var(--radius-lg);
  padding: 32px;
  text-align: center;
  margin: 32px 0;
}
.newsletter h3 { font-size: 24px; color: #fff; margin-bottom: 8px; }
.newsletter p { color: var(--text-muted); font-size: 13px; margin-bottom: 20px; }
.newsletter-form { display: flex; gap: 10px; max-width: 420px; margin: 0 auto; }
.newsletter-form input {
  flex: 1;
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 12px 16px;
  color: var(--text);
  font-family: 'Exo 2', sans-serif;
  font-size: 14px;
  outline: none;
  transition: border-color 0.2s;
}
.newsletter-form input:focus { border-color: var(--neon-blue); }
.newsletter-form input::placeholder { color: var(--text-dim); }
.btn-primary {
  background: linear-gradient(135deg, var(--neon-blue), var(--neon-purple));
  color: #fff;
  border: none;
  border-radius: var(--radius);
  padding: 12px 24px;
  font-family: 'Rajdhani', sans-serif;
  font-weight: 700;
  font-size: 13px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  cursor: pointer;
  transition: opacity 0.2s, transform 0.15s;
  white-space: nowrap;
}
.btn-primary:hover { opacity: 0.9; transform: translateY(-1px); }

/* ── COMMENTS ── */
.comment {
  display: flex;
  gap: 12px;
  padding: 16px 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}
.comment:last-child { border-bottom: none; }
.avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Rajdhani', sans-serif;
  font-size: 14px;
  font-weight: 700;
  flex-shrink: 0;
}
.avatar-blue { background: rgba(0,212,255,0.2); color: var(--neon-blue); border: 1px solid rgba(0,212,255,0.3); }
.avatar-purple { background: rgba(139,92,246,0.2); color: #a78bfa; border: 1px solid rgba(139,92,246,0.3); }
.avatar-green { background: rgba(0,255,136,0.15); color: var(--neon-green); border: 1px solid rgba(0,255,136,0.3); }
.comment-name { font-family: 'Rajdhani', sans-serif; font-size: 14px; font-weight: 700; color: #fff; }
.comment-time { font-size: 11px; color: var(--text-dim); margin-left: 8px; }
.comment-text { font-size: 13px; color: var(--text-muted); margin-top: 4px; line-height: 1.5; }
.comment-likes { font-size: 12px; color: var(--text-dim); margin-top: 6px; cursor: pointer; transition: color 0.2s; }
.comment-likes:hover { color: var(--neon-blue); }

.comment-input-area {
  display: flex;
  gap: 12px;
  padding-top: 16px;
}
.comment-input {
  flex: 1;
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 10px 14px;
  color: var(--text);
  font-family: 'Exo 2', sans-serif;
  font-size: 13px;
  outline: none;
  transition: border-color 0.2s;
}
.comment-input:focus { border-color: var(--neon-blue); }
.comment-input::placeholder { color: var(--text-dim); }

/* ── FOOTER ── */
footer {
  background: var(--bg2);
  border-top: 1px solid var(--border);
  padding: 48px 20px 24px;
  margin-top: 48px;
}
.footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 40px; max-width: 1280px; margin: 0 auto 40px; }
@media(max-width:768px){ .footer-grid { grid-template-columns: 1fr 1fr; gap: 24px; } }
@media(max-width:480px){ .footer-grid { grid-template-columns: 1fr; } }
.footer-logo { font-family: 'Rajdhani', sans-serif; font-size: 24px; font-weight: 700; color: #fff; margin-bottom: 12px; }
.footer-desc { font-size: 13px; color: var(--text-muted); line-height: 1.6; margin-bottom: 20px; }
.social-links { display: flex; gap: 10px; }
.social-link {
  width: 36px;
  height: 36px;
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  display: flex;
  align-items: center;
  justify-content: center;
